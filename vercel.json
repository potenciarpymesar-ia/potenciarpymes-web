{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path(.*)\\.html",
      "destination": "/:path",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.potenciarpymes.ar" }],
      "destination": "https://potenciarpymes.ar/$1",
      "permanent": true
    }
  ]
}
